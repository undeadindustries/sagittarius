# Environment variables (copy to .env for local development — never commit .env)

# Google Gemini API key (Phase 05+)
# GOOGLE_API_KEY=

# OpenAI or OpenAI-compatible provider API key (Phase 06+)
# OPENAI_API_KEY=

# Force encrypted file credential storage when OS keychain is unavailable (Phase 03+)
# GEMINI_FORCE_FILE_STORAGE=1

# Optional: override default model or provider via settings.json in Phase 02+
